DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=
DB_NAME=bna_db
DB_USER=bna_user
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
REDIS_URL=redis://localhost:6379/0
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Celery — set to False to use real Redis + worker for async notifications
CELERY_EAGER=True

# Email SMTP — set EMAIL_HOST to enable real email sending (Gmail, Mailtrap, etc.)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=dijj xfeb qvwx pqgn
DEFAULT_FROM_EMAIL=

# Gmail OAuth 2.0 — leave blank to fall back to console / SMTP backend
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=
GMAIL_OAUTH_SENDER=

# OpenAI API for Chatbot (optional - set USE_OPENAI=True to enable)
OPENAI_API_KEY=
USE_OPENAI=False

# Google Gemini API for Chatbot (use GOOGLE_API_KEY or GEMINI_API_KEY)
GOOGLE_API_KEY=
GEMINI_API_KEY=




